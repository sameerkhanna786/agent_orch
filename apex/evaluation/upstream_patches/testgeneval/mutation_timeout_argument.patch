                 tasks.append(task)
@@ -225,5 +232,11 @@ if __name__ == "__main__":
     parser.add_argument(
         "--skip_mutation", action="store_true", help="(Optional) Skip mutation"
     )
+    parser.add_argument(
+        "--mutation_timeout",
+        type=int,
+        help="(Optional) Mutation phase timeout in seconds (default: 3600)",
+        default=3600,
+    )
     args = parser.parse_args()
     asyncio.run(main(**vars(args)))
